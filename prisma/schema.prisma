generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Professional {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  slug            String   @unique
  specialty       String   @default("psychology")
  bio             String?
  avatarUrl       String?
  phone           String?
  sessionPrice       Float    @default(15000)
  depositPercent     Int      @default(30)
  sessionDuration    Int      @default(50)
  plan               String   @default("basic")
  active             Boolean  @default(true)
  transferAlias      String?                    // alias/CBU/CVU para transferencias
  mpSurchargePercent Float    @default(0)       // recargo % aplicado al cobrar con MP
  // Suscripcion / acceso
  subscriptionStatus    String    @default("trial")   // trial | beta | active | past_due | cancelled
  subscriptionExpiresAt DateTime?                     // null = sin limite (admins, soporte)
  mpSubscriptionId      String?                       // se usa cuando arranque MP Suscripciones (Fase 2)
  onboardingCompletedAt DateTime?                     // marca que el pro paso por /bienvenida
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  availability        Availability[]
  appointments        Appointment[]
  patients            Patient[]
  notifications       Notification[]
  pushSubscriptions   PushSubscription[]
  betaCodeRedemption  BetaCodeRedemption?
  feedback            Feedback[]
}

// Codigo que un profesional canjea para arrancar con 90 dias gratis (configurable).
// Generamos en lote via script y los repartimos manualmente (WhatsApp, mail).
model BetaCode {
  id               String    @id @default(cuid())
  code             String    @unique
  validForDays     Int       @default(90)
  maxRedemptions   Int       @default(1)
  redemptionsCount Int       @default(0)
  expiresAt        DateTime?                          // si no se canjea antes, queda invalidado
  notes            String?                            // contexto interno: "campania ig", "amigo X"
  createdAt        DateTime  @default(now())

  redemptions      BetaCodeRedemption[]
}

// Un pro solo puede canjear UN codigo de por vida (unique en professionalId).
model BetaCodeRedemption {
  id             String   @id @default(cuid())
  codeId         String
  professionalId String   @unique
  redeemedAt     DateTime @default(now())

  code         BetaCode     @relation(fields: [codeId], references: [id])
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
}

// Feedback in-app de profesionales en beta. Usado para iterar antes del paywall.
model Feedback {
  id             String   @id @default(cuid())
  professionalId String
  message        String
  rating         Int?
  createdAt      DateTime @default(now())

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
}

model Patient {
  id             String   @id @default(cuid())
  professionalId String
  name           String
  phone          String
  email          String?
  notes          String?
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@unique([professionalId, phone])
}

model Appointment {
  id              String   @id @default(cuid())
  professionalId  String
  patientId       String?
  patientName     String
  patientPhone    String
  patientEmail    String?
  date            DateTime
  durationMin     Int      @default(50)
  status               String    @default("pending")
  paymentStatus        String    @default("unpaid")
  depositAmount        Float?
  totalAmount          Float?
  mpPaymentId          String?
  mpPreferenceId       String?
  notes                String?
  reminder48hSent      Boolean   @default(false)
  reminder2hSent       Boolean   @default(false)
  // Campos para transferencia bancaria
  paymentMethod        String    @default("mercadopago")   // "mercadopago" | "transferencia"
  transferProofRef     String?                             // número de comprobante ingresado por el paciente
  transferExpiresAt    DateTime?                           // cuándo expira la reserva pendiente (24hs)
  transferConfirmedAt  DateTime?                           // cuándo el profesional confirmó
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  patient      Patient?     @relation(fields: [patientId], references: [id])
}

model Notification {
  id             String   @id @default(cuid())
  professionalId String
  type           String   // "new_transfer" | "new_mp_payment" | "transfer_confirmed" | "transfer_rejected"
  title          String
  body           String
  read           Boolean  @default(false)
  appointmentId  String?  // referencia opcional al turno
  createdAt      DateTime @default(now())

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id             String   @id @default(cuid())
  professionalId String
  endpoint       String   @unique
  p256dh         String
  auth           String
  createdAt      DateTime @default(now())

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
}

model Availability {
  id             String  @id @default(cuid())
  professionalId String
  dayOfWeek      Int
  startTime      String
  endTime        String
  slotDuration   Int     @default(50)
  active         Boolean @default(true)

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, dayOfWeek])
}
